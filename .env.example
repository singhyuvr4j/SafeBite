# ============================================
# DATABASE CONFIGURATION
# ============================================
# SafeBite supports multiple database backends.
# Choose one of the following options:
#
# 1. Supabase (PostgreSQL) - Recommended
#    Get your connection string from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/database
#    DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
#
# 2. Neon (PostgreSQL)
#    Get your connection string from: https://neon.tech
#    DATABASE_URL="postgresql://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=require"
#
# 3. MongoDB Atlas
#    Get your connection string from: https://www.mongodb.com/atlas
#    DATABASE_URL="mongodb+srv://[username]:[password]@[cluster].mongodb.net/[dbname]?retryWrites=true&w=majority"
#
# 4. SQLite (Development only - not recommended for production)
#    DATABASE_URL="file:./db/custom.db"
#
# Note: If using MongoDB, also update the provider in prisma/schema.prisma to "mongodb"
# ============================================

# Supabase PostgreSQL Example (Recommended)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# ============================================
# NVIDIA NIM API
# ============================================
# Get your free API key at: https://build.nvidia.com/
NVIDIA_API_KEY="your_nvidia_nim_api_key_here"
